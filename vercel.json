{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!css/|js/).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(css|js)/(.+)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
